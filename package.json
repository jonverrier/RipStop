{
  "name": "@jonverrier/ripstop",
  "version": "0.2.0",
  "description": "Git hook and CI guardrails for AI-assisted software development",
  "private": false,
  "type": "commonjs",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "ripstop": "dist/src/cli.js"
  },
  "directories": {
    "src": "src",
    "test": "test",
    "doc": "docs"
  },
  "files": [
    "dist/src/**/*",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonverrier/RipStop.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": "Jon Verrier",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc -b && node scripts/copy-assets.js",
    "prepare": "npm run build",
    "clean": "rimraf dist coverage .nyc_output",
    "prepublishOnly": "npm run build",
    "test": "npm run test:ci",
    "test:ci": "npm run build && mocha --no-config dist/test/Config.test.js dist/test/Cli.test.js dist/test/Checks.test.js dist/test/GenerateMd.test.js dist/test/Recover.test.js --exit",
    "cover": "nyc --reporter=html --reporter=text --reporter=lcov --extension .ts --exclude \"**/*.test.ts\" --exclude \"test/**\" npm run test:ci"
  },
  "dependencies": {
    "@jonverrier/assistant-common": "^0.3.2",
    "js-yaml": "^4.1.0",
    "picomatch": "^4.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.10",
    "expect": "^29.7.0",
    "mocha": "^11.7.1",
    "nyc": "^17.1.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "nyc": {
    "include": [
      "src/**/*.ts"
    ],
    "extension": [
      ".ts"
    ],
    "exclude": [
      "**/*.d.ts",
      "**/*.test.ts",
      "test/**",
      "dist/**",
      "coverage/**",
      "node_modules/**"
    ],
    "reporter": [
      "html",
      "text",
      "lcov"
    ],
    "all": true,
    "check-coverage": false
  }
}
