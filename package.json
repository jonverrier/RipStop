{
  "name": "@jonverrier/ripstop",
  "version": "0.2.1",
  "description": "Git hook and CI guardrails for AI-assisted software development",
  "private": false,
  "type": "commonjs",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "ripstop": "dist/src/cli.js"
  },
  "directories": {
    "src": "src",
    "test": "test",
    "doc": "docs"
  },
  "files": [
    "dist/src/**/*",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonverrier/RipStop.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": "Jon Verrier",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc -b && node scripts/copy-assets.js",
    "prepare": "npm run build",
    "clean": "rimraf dist coverage",
    "prepublishOnly": "npm run build",
    "test": "jest --selectProjects unit",
    "test:ci": "jest --selectProjects ci",
    "cover": "jest --selectProjects ci --coverage --coverageReporters=html text lcov"
  },
  "dependencies": {
    "@jonverrier/assistant-common": "^0.3.4",
    "js-yaml": "^4.1.0",
    "picomatch": "^4.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.10",
    "expect": "^29.7.0",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "typescript": "5.9.3"
  }
}
